#------OpenTunnel.net------
client
dev tun
proto udp
remote sgo-1.vip-svr.com 1194
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server

# Security Settings
cipher AES-256-GCM
data-ciphers AES-256-GCM:AES-128-GCM
auth-nocache

# Auth & Logic
auth-user-pass
explicit-exit-notify
route-method exe
verb 3
setenv CLIENT_CERT 0
